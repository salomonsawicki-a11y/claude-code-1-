# ----------------------------------------------------------------------------
# Margin — environment configuration
# Copy this file to ".env.local" and fill in your keys. Never commit .env.local.
# ----------------------------------------------------------------------------

# REQUIRED. Powers the discovery and resell agents.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OPTIONAL. Model the agents run on. Defaults to claude-opus-4-8.
# ANTHROPIC_MODEL=claude-opus-4-8

# OPTIONAL — eBay Browse API (real marketplace sourcing).
# When set, the discovery agent augments its web search with live eBay listings.
# Create an app at https://developer.ebay.com/ (Production keyset).
# EBAY_CLIENT_ID=
# EBAY_CLIENT_SECRET=
# EBAY_MARKETPLACE_ID=EBAY_US
